# Bind on all interfaces so Docker port mappings reach the container.
{
    default_bind 0.0.0.0
    admin off
}

# Shared route matchers (apply to both http and https blocks via snippets).
# /me and /me/* → user-apigw
# PATCH /admin/users/* → user-apigw (will move to admin-lambda in phase 2)
# everything else → auth-apigw

(routes) {
    handle /static/* {
        root * /srv
        file_server
    }

    @user_routes path /me /me/*
    handle @user_routes {
        reverse_proxy user-apigw:3000
    }

    @admin_users_patch {
        path /admin/users/*
        method PATCH
    }
    handle @admin_users_patch {
        reverse_proxy user-apigw:3000
    }

    handle {
        reverse_proxy auth-apigw:3000
    }
}

# HTTP — for non-Safari dev testing
localhost:9000 {
    import routes
}

# HTTPS — required for Safari WebAuthn (navigator.credentials)
# Caddy auto-generates a local CA cert. Accept the browser warning, or:
#   docker compose exec caddy caddy trust
localhost:9001 {
    import routes
}
